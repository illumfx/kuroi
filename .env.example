POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

APP_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
IMAGE_TAG=latest
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=
VITE_OIDC_ENABLED=false

# Optional Traefik override values (for docker-compose.traefik.yml)
TRAEFIK_NETWORK=traefik_proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_DOMAIN=SET_ME_FRONTEND_DOMAIN
TRAEFIK_TLS=true

OIDC_ENABLED=false
OIDC_ISSUER_URL=https://authelia.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/oidc/callback
OIDC_TOKEN_AUTH_METHOD=auto
OIDC_USE_PKCE=true

STEAM_API_KEY=
